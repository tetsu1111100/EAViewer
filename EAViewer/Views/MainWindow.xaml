<ui:FluentWindow x:Class="EAViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:EAViewer.ViewModels"
        xmlns:controls="clr-namespace:EAViewer.Views.Controls"
        Title="EA Viewer - Table Schema Browser"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="EA Viewer" ShowMaximize="True" ShowMinimize="True"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" 
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <WrapPanel VerticalAlignment="Center">
                <!-- Search -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <ui:TextBox x:Name="SearchBox"
                                PlaceholderText="輸入 Table Name 搜尋..."
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                Width="300"
                                KeyDown="SearchBox_KeyDown"
                                VerticalAlignment="Center"/>
                    <ui:Button Content="Search"
                               Icon="{ui:SymbolIcon Search24}"
                               Appearance="Primary"
                               Command="{Binding SearchCommand}"
                               IsEnabled="{Binding IsSearching, Converter={StaticResource InverseBoolConverter}}"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Open New -->
                <ui:Button Content="Open New"
                           Icon="{ui:SymbolIcon WindowNew20}"
                           Command="{Binding OpenNewCommand}"
                           Margin="0,0,16,0"
                           VerticalAlignment="Center"/>

                <!-- Lowercase CheckBox -->
                <CheckBox Content="ColName 轉小寫"
                          IsChecked="{Binding IsLowerCaseColName}"
                          VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- Canvas Area -->
        <ScrollViewer Grid.Row="2" 
                      x:Name="CanvasScrollViewer"
                      HorizontalScrollBarVisibility="Auto" 
                      VerticalScrollBarVisibility="Auto"
                      Background="#F5F5F5"
                      PreviewMouseLeftButtonDown="Canvas_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="Canvas_PreviewMouseMove"
                      PreviewMouseLeftButtonUp="Canvas_PreviewMouseLeftButtonUp">
            <ItemsControl ItemsSource="{Binding TableGrids}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas x:Name="MainCanvas" 
                                Width="5000" Height="5000"
                                Background="#F5F5F5"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding CanvasX}"/>
                        <Setter Property="Canvas.Top" Value="{Binding CanvasY}"/>
                        <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TableGridViewModel}">
                        <controls:TableGridControl DataContext="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- No Data Message Overlay -->
        <Border Grid.Row="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,40,0,0"
                Padding="24,12"
                CornerRadius="8"
                Visibility="{Binding IsNoDataVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                IsHitTestVisible="False">
            <Border.Background>
                <SolidColorBrush Color="#333333" Opacity="0.85"/>
            </Border.Background>
            <TextBlock Text="查無資料表"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}"
                IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal">
                <ui:ProgressRing IsIndeterminate="True" Width="24" Height="24"/>
                <TextBlock Text="搜尋中..." Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
