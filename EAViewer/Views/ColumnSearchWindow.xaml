<Window x:Class="EAViewer.Views.ColumnSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="欄位搜尋"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Deactivated="Window_Deactivated">
        
    <Border Background="White" 
            BorderBrush="#D0D0D0" 
            BorderThickness="1" 
            CornerRadius="6" 
            Padding="12,10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="6" Direction="270" ShadowDepth="2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Search20" Foreground="#0078D4" Margin="0,0,6,0"/>
                    <TextBlock x:Name="ColumnLabel" FontWeight="Bold" Foreground="#333" FontSize="13"/>
                </StackPanel>
                <ui:Button Grid.Column="1" 
                           Icon="{ui:SymbolIcon Dismiss20}" 
                           Appearance="Transparent" 
                           Padding="2" 
                           Margin="8,-4,-4,0" 
                           Click="CloseButton_Click"
                           Cursor="Hand"/>
            </Grid>
            
            <!-- Input Row -->
            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <ui:TextBox x:Name="SearchInput"
                            PlaceholderText="輸入搜尋文字..."
                            KeyDown="SearchInput_KeyDown"
                            Width="200"
                            VerticalAlignment="Center"/>
                <ui:Button Content="搜尋"
                           Appearance="Primary"
                           Click="SearchButton_Click"
                           Margin="8,0,0,0"
                           Padding="12,4"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
